NODE_ENV=development
PORT=8080

# MongoDB configuration
MONGODB_URL=mongodb://localhost:27017/leaflens
MONGODB_DB=leaflens

# JWT configuration
# Generate a random secret using a secure method in windows, linux, macos, or online tools. For example, you can use the following command in a terminal:
# openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRATION=86400

# Gemini SDK configuration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# S3-compatible object storage (used for saved leaf images)
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
