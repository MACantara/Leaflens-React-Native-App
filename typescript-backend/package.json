{
  "name": "leaflens-typescript-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "images:backfill-1080p": "tsx src/scripts/resizeStorageImagesTo1080p.ts",
    "db:migrate:delete-non-applicable-leaves": "tsx src/scripts/deleteNonApplicableLeaves.ts",
    "db:migrate:remove-ai-references": "tsx src/scripts/removeAiGeneratedReferences.ts",
    "db:migrate:backfill-image-visibility": "tsx src/scripts/backfillLeafImageVisibilityMetadata.ts",
    "db:wipe:plants": "tsx src/scripts/wipeAllPlantRecords.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@google/genai": "^1.48.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb": "^6.19.0",
    "multer": "^2.1.1",
    "sharp": "^0.34.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "~5.8.3"
  }
}
