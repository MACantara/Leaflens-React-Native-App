{
  "expo": {
    "name": "Leaflens MVP",
    "slug": "leaflens-mvp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Leaflens needs access to your photos so you can upload leaf images.",
          "cameraPermission": "Leaflens needs camera access so you can capture leaf photos."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
