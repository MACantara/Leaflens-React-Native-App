{
  "expo": {
    "name": "LeafLens",
    "slug": "leaflens",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.leaflens.mobile",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "permissions": [
        "REQUEST_INSTALL_PACKAGES"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Leaflens needs access to your photos so you can upload leaf images.",
          "cameraPermission": "Leaflens needs camera access so you can capture leaf photos."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "web": {
      "bundler": "metro"
    }
  }
}
